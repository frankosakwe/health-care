NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
DB_PATH=./database/healthcare.db
REDIS_URL=redis://localhost:6379
CACHE_TTL=300
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_ISSUER_PUBLIC_KEY=your_stellar_issuer_public_key
STELLAR_ISSUER_SECRET_KEY=your_stellar_issuer_secret_key

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal Payment Configuration
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# IPFS Configuration
IPFS_NODE_TYPE=local
INFURA_PROJECT_ID=your_infura_project_id
INFURA_PROJECT_SECRET=your_infura_project_secret

# Encryption
DEFAULT_ENCRYPTION_KEY=your-default-encryption-key-here

# IPFS Settings
MAX_VERSIONS=10
AUTO_BACKUP=true
BACKUP_RETENTION_DAYS=30
PINNING_MAX_RETRIES=3
PINNING_RETRY_DELAY=5000
HEALTH_CHECK_INTERVAL=60000
CLEANUP_DAYS=30
